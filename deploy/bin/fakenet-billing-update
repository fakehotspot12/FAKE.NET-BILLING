#!/usr/bin/env bash
set -euo pipefail

APP_DIR="${APP_DIR:-/opt/fakenet-billing}"
BACKUP_DIR="${FAKENET_BACKUP_DIR:-/var/backups/fakenet-billing}"
LOG_DIR="${FAKENET_LOG_DIR:-/var/log/fakenet-billing}"
LOG_FILE="${FAKENET_UPDATE_LOG:-$LOG_DIR/update.log}"
LOCK_FILE="${FAKENET_UPDATE_LOCK:-/tmp/fakenet-billing-update.lock}"
LOCK_MAX_AGE_SECONDS="${FAKENET_UPDATE_LOCK_MAX_AGE_SECONDS:-3600}"
STACK_CMD="${FAKENET_STACK_CMD:-/usr/local/bin/fakenet-billing-stack}"
ARCHIVE_URL="${FAKENET_UPDATE_ARCHIVE_URL:-}"
BRANCH="${FAKENET_UPDATE_BRANCH:-}"
ENV_FILE="${FAKENET_ENV_FILE:-/etc/fakenet-billing.env}"
WAHA_ENV_FILE="${FAKENET_WAHA_ENV_FILE:-/etc/fakenet-billing-waha.env}"

mkdir -p "$BACKUP_DIR" "$LOG_DIR"
exec >>"$LOG_FILE" 2>&1

echo
echo "[$(date -Is)] Update dimulai"

lock_age_seconds() {
  local modified now
  modified="$(stat -c %Y "$LOCK_FILE" 2>/dev/null || echo 0)"
  now="$(date +%s)"
  if [ "$modified" -gt 0 ] 2>/dev/null; then
    echo $((now - modified))
  else
    echo "$LOCK_MAX_AGE_SECONDS"
  fi
}

lock_process_is_updater() {
  local pid="$1" command
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null || return 1
  command="$(tr '\0' ' ' < "/proc/$pid/cmdline" 2>/dev/null || true)"
  printf '%s' "$command" | grep -q 'fakenet-billing-update'
}

acquire_update_lock() {
  local attempt lock_pid lock_age
  for attempt in 1 2 3; do
    if (set -o noclobber; printf '%s\n' "$$" > "$LOCK_FILE") 2>/dev/null; then
      return 0
    fi
    lock_pid="$(cat "$LOCK_FILE" 2>/dev/null || true)"
    lock_age="$(lock_age_seconds)"
    if lock_process_is_updater "$lock_pid" && [ "$lock_age" -lt "$LOCK_MAX_AGE_SECONDS" ]; then
      echo "Update lain masih berjalan: $LOCK_FILE (pid $lock_pid)"
      return 1
    fi
    echo "Lock update stale ditemukan dan dibersihkan: $LOCK_FILE (pid ${lock_pid:-tidak-valid}, umur ${lock_age}s)"
    rm -f "$LOCK_FILE"
  done
  echo "Lock update tidak bisa dibuat: $LOCK_FILE" >&2
  return 1
}

release_update_lock() {
  local lock_pid
  lock_pid="$(cat "$LOCK_FILE" 2>/dev/null || true)"
  if [ "$lock_pid" = "$$" ]; then
    rm -f "$LOCK_FILE"
  fi
}

tmp_backup_dir=""
tmpdir=""
cleanup_update() {
  release_update_lock
  [ -n "$tmp_backup_dir" ] && rm -rf "$tmp_backup_dir"
  [ -n "$tmpdir" ] && rm -rf "$tmpdir"
}

acquire_update_lock
trap cleanup_update EXIT

if [ ! -d "$APP_DIR" ]; then
  echo "APP_DIR tidak ditemukan: $APP_DIR"
  exit 1
fi

load_env_file() {
  if [ -f "$ENV_FILE" ]; then
    set -a
    # shellcheck disable=SC1090
    . "$ENV_FILE"
    set +a
  fi
}

database_url_for_name() {
  local explicit_url="$1" db_name="$2" db_user="$3" db_password="$4"
  if [ -n "$explicit_url" ]; then
    printf '%s\n' "$explicit_url"
    return 0
  fi
  if [ -n "$db_name" ] && [ -n "$db_user" ] && [ -n "$db_password" ]; then
    printf 'postgres://%s:%s@127.0.0.1:5432/%s\n' "$db_user" "$db_password" "$db_name"
  fi
}

dump_database() {
  local label="$1" url="$2" output="$3"
  if [ -z "$url" ]; then
    echo "Lewati dump $label: URL database kosong"
    return 0
  fi
  if ! command -v pg_dump >/dev/null 2>&1; then
    echo "Lewati dump $label: pg_dump tidak tersedia"
    return 0
  fi
  echo "Dump database $label ke $output"
  pg_dump --no-owner --no-privileges --format=custom --file="$output" "$url"
}

write_manifest() {
  local manifest="$1"
  {
    echo "app=fakenet-billing"
    echo "created_at=$(date -Is)"
    echo "app_dir=$APP_DIR"
    echo "source_mode=$([ -d "$APP_DIR/.git" ] && echo git || echo archive)"
    if [ -d "$APP_DIR/.git" ]; then
      echo "git_remote=$(git -C "$APP_DIR" remote get-url origin 2>/dev/null || true)"
      echo "git_branch=$(git -C "$APP_DIR" branch --show-current 2>/dev/null || true)"
      echo "git_commit=$(git -C "$APP_DIR" rev-parse HEAD 2>/dev/null || true)"
      echo "git_status_short_begin"
      git -C "$APP_DIR" status --short --untracked-files=no 2>/dev/null || true
      echo "git_status_short_end"
    fi
    echo "node_version=$(node -v 2>/dev/null || true)"
    echo "npm_version=$(npm -v 2>/dev/null || true)"
  } > "$manifest"
}

safe_copy_if_exists() {
  local source="$1" target_dir="$2"
  if [ -e "$source" ]; then
    mkdir -p "$target_dir"
    cp -a "$source" "$target_dir/"
  fi
}

create_pre_update_backup() {
  load_env_file

  local stamp backup_file app_db_url radius_db_url
  stamp="$(date +%Y%m%d%H%M%S)"
  backup_file="$BACKUP_DIR/fakenet-billing-pre-update-$stamp.tar.gz"
  tmp_backup_dir="$(mktemp -d)"

  echo "Menyiapkan backup pre-update di $tmp_backup_dir"
  mkdir -p "$tmp_backup_dir/app" "$tmp_backup_dir/etc" "$tmp_backup_dir/db"

  safe_copy_if_exists "$APP_DIR/data" "$tmp_backup_dir/app"
  safe_copy_if_exists "$APP_DIR/.env.example" "$tmp_backup_dir/app"
  safe_copy_if_exists "$APP_DIR/package.json" "$tmp_backup_dir/app"
  safe_copy_if_exists "$APP_DIR/package-lock.json" "$tmp_backup_dir/app"
  safe_copy_if_exists "$APP_DIR/deploy/fakenet-billing.env" "$tmp_backup_dir/app/deploy"
  safe_copy_if_exists "$APP_DIR/deploy/fakenet-billing-waha.env" "$tmp_backup_dir/app/deploy"
  safe_copy_if_exists "$ENV_FILE" "$tmp_backup_dir/etc"
  safe_copy_if_exists "$WAHA_ENV_FILE" "$tmp_backup_dir/etc"
  write_manifest "$tmp_backup_dir/manifest.txt"

  app_db_url="$(database_url_for_name "${DATABASE_URL:-${POSTGRES_URL:-}}" "${APP_DATABASE_NAME:-}" "${APP_DATABASE_USER:-}" "${APP_DATABASE_PASSWORD:-}")"
  radius_db_url="$(database_url_for_name "${FREERADIUS_DATABASE_URL:-${FREERADIUS_DB_URL:-}}" "${RADIUS_DATABASE_NAME:-}" "${RADIUS_DATABASE_USER:-}" "${RADIUS_DATABASE_PASSWORD:-}")"
  dump_database app "$app_db_url" "$tmp_backup_dir/db/fakenet_billing.dump"
  dump_database radius "$radius_db_url" "$tmp_backup_dir/db/radius.dump"

  tar -czf "$backup_file" -C "$tmp_backup_dir" .
  rm -rf "$tmp_backup_dir"
  tmp_backup_dir=""
  echo "Backup pre-update selesai: $backup_file"
}

create_pre_update_backup

if [ -d "$APP_DIR/.git" ]; then
  echo "Update via git pull"
  git -C "$APP_DIR" fetch --all --prune
  if [ -n "$BRANCH" ]; then
    git -C "$APP_DIR" checkout "$BRANCH"
  fi
  dirty_status="$(git -C "$APP_DIR" status --short --untracked-files=no 2>/dev/null || true)"
  if [ -n "$dirty_status" ]; then
    echo "Worktree memiliki perubahan lokal tracked file; simpan sementara ke git stash"
    git -C "$APP_DIR" stash push -m "fakenet-billing-pre-update-$(date +%Y%m%d%H%M%S)" -- . || true
  fi
  git -C "$APP_DIR" pull --ff-only
elif [ -n "$ARCHIVE_URL" ]; then
  echo "Update via archive $ARCHIVE_URL"
  tmpdir="$(mktemp -d)"
  curl -fsSL "$ARCHIVE_URL" -o "$tmpdir/source.tar.gz"
  mkdir -p "$tmpdir/source"
  tar -xzf "$tmpdir/source.tar.gz" -C "$tmpdir/source" --strip-components=1
  rsync -a --delete \
    --exclude data \
    --exclude node_modules \
    --exclude .env \
    --exclude deploy/fakenet-billing.env \
    --exclude deploy/fakenet-billing-waha.env \
    "$tmpdir/source/" "$APP_DIR/"
else
  echo "Tidak ada .git atau FAKENET_UPDATE_ARCHIVE_URL. Source tidak berubah."
fi

cd "$APP_DIR"
if command -v npm >/dev/null 2>&1; then
  if [ -f package-lock.json ]; then
    npm ci --omit=dev
  else
    npm install --omit=dev
  fi
  node -e "require('bullmq'); require('./src/whatsapp-queue')" >/dev/null
fi

if [ -f "$APP_DIR/deploy/bin/fakenet-billing-update" ]; then
  install -m 0755 "$APP_DIR/deploy/bin/fakenet-billing-update" /usr/local/bin/fakenet-billing-update || true
fi
if [ -f "$APP_DIR/deploy/bin/fakenet-billing-stack" ]; then
  install -m 0755 "$APP_DIR/deploy/bin/fakenet-billing-stack" /usr/local/bin/fakenet-billing-stack || true
fi

if [ -f "$APP_DIR/install.sh" ]; then
  APP_DIR="$APP_DIR" REPAIR_FREERADIUS=0 bash "$APP_DIR/install.sh" repair || true
fi

if command -v systemctl >/dev/null 2>&1; then
  systemctl daemon-reload || true
  if [ -x "$STACK_CMD" ]; then
    "$STACK_CMD" restart-app
  else
    systemctl restart fakenet-billing.service
  fi
elif command -v rc-service >/dev/null 2>&1; then
  if [ -x "$STACK_CMD" ]; then
    "$STACK_CMD" restart-app
  else
    rc-service fakenet-billing restart || true
    rc-service fakenet-billing-isolir restart || true
    rc-service fakenet-billing-voucher restart || true
    rc-service fakenet-billing-wifiku restart || true
    rc-service fakenet-billing-radius-connector restart || true
    rc-service fakenet-billing-waha restart || true
  fi
fi

health_ok=0
for attempt in $(seq 1 30); do
  health_payload="$(curl -fsS --max-time 3 http://127.0.0.1:8891/api/health 2>/dev/null || true)"
  if printf '%s' "$health_payload" | grep -q '"ok":true' \
    && printf '%s' "$health_payload" | grep -q '"backend":"bullmq"' \
    && printf '%s' "$health_payload" | grep -q '"available":true'; then
    health_ok=1
    break
  fi
  sleep 1
done
if [ "$health_ok" -ne 1 ]; then
  echo "Health check Billing/BullMQ gagal setelah update." >&2
  exit 1
fi
echo "Health check Billing dan BullMQ berhasil"

echo "[$(date -Is)] Update selesai"
