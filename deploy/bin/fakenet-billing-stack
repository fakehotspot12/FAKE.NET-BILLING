#!/usr/bin/env bash
set -euo pipefail

ACTION="${1:-status}"

APP_UNITS=(
  fakenet-billing.service
  fakenet-billing-isolir.service
  fakenet-billing-voucher.service
  fakenet-billing-wifiku.service
  fakenet-billing-radius-connector.service
  fakenet-billing-waha.service
)

APP_SERVICES=(
  fakenet-billing
  fakenet-billing-isolir
  fakenet-billing-voucher
  fakenet-billing-wifiku
  fakenet-billing-radius-connector
  fakenet-billing-waha
)

SYSTEMD_BASE_GROUPS=(
  "redis-server.service redis.service"
  "postgresql.service postgresql@15-main.service postgresql@14-main.service postgresql@13-main.service"
  "freeradius.service radiusd.service"
  "docker.service"
)

OPENRC_BASE_SERVICES=(redis postgresql freeradius radiusd docker)
UPDATE_LOCK_FILE="${FAKENET_UPDATE_LOCK:-/tmp/fakenet-billing-update.lock}"

clear_stale_update_lock() {
  local pid command
  [ -e "$UPDATE_LOCK_FILE" ] || {
    echo "Lock update tidak ada."
    return 0
  }
  pid="$(cat "$UPDATE_LOCK_FILE" 2>/dev/null || true)"
  command=""
  if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
    command="$(tr '\0' ' ' < "/proc/$pid/cmdline" 2>/dev/null || true)"
  fi
  if printf '%s' "$command" | grep -q 'fakenet-billing-update'; then
    echo "Update masih aktif pada PID $pid; lock tidak dihapus." >&2
    return 1
  fi
  rm -f "$UPDATE_LOCK_FILE"
  echo "Lock update stale sudah dihapus: $UPDATE_LOCK_FILE"
}

systemd_unit_exists() {
  systemctl list-unit-files "$1" --no-legend >/dev/null 2>&1
}

resolve_systemd_group() {
  local unit
  for unit in "$@"; do
    if systemd_unit_exists "$unit"; then
      printf '%s\n' "$unit"
      return 0
    fi
  done
  return 1
}

systemd_base_units() {
  local group unit
  for group in "${SYSTEMD_BASE_GROUPS[@]}"; do
    unit="$(resolve_systemd_group $group || true)"
    [ -n "$unit" ] && printf '%s\n' "$unit"
  done
}

systemd_units() {
  systemd_base_units
  printf '%s\n' "${APP_UNITS[@]}"
}

restart_unit() {
  local unit="$1"
  if systemctl restart "$unit"; then
    return 0
  fi
  systemctl start "$unit" || true
  systemctl is-active --quiet "$unit"
}

openrc_service_exists() {
  [ -x "/etc/init.d/$1" ]
}

openrc_services() {
  local service
  for service in "${OPENRC_BASE_SERVICES[@]}" "${APP_SERVICES[@]}"; do
    openrc_service_exists "$service" && printf '%s\n' "$service"
  done
}

run_systemd() {
  mapfile -t units < <(systemd_units)
  case "$ACTION" in
    start)
      systemctl start "${units[@]}"
      ;;
    restart)
      failed=0
      for unit in "${units[@]}"; do
        restart_unit "$unit" || failed=1
      done
      return "$failed"
      ;;
    restart-app)
      failed=0
      for unit in "${APP_UNITS[@]}"; do
        restart_unit "$unit" || failed=1
      done
      return "$failed"
      ;;
    stop)
      systemctl stop "${APP_UNITS[@]}" || true
      ;;
    status)
      systemctl status "${units[@]}" --no-pager
      ;;
    update)
      /usr/local/bin/fakenet-billing-update
      ;;
    clear-update-lock)
      clear_stale_update_lock
      ;;
    *)
      echo "Usage: fakenet-billing-stack {start|restart|restart-app|stop|status|update|clear-update-lock}" >&2
      exit 2
      ;;
  esac
}

run_openrc() {
  mapfile -t services < <(openrc_services)
  case "$ACTION" in
    start)
      for service in "${services[@]}"; do rc-service "$service" start || true; done
      ;;
    restart)
      failed=0
      for service in "${services[@]}"; do
        rc-service "$service" restart || rc-service "$service" start || failed=1
      done
      return "$failed"
      ;;
    restart-app)
      failed=0
      for service in "${APP_SERVICES[@]}"; do
        openrc_service_exists "$service" || continue
        rc-service "$service" restart || rc-service "$service" start || failed=1
      done
      return "$failed"
      ;;
    stop)
      for service in "${APP_SERVICES[@]}"; do openrc_service_exists "$service" && rc-service "$service" stop || true; done
      ;;
    status)
      for service in "${services[@]}"; do rc-service "$service" status || true; done
      ;;
    update)
      /usr/local/bin/fakenet-billing-update
      ;;
    clear-update-lock)
      clear_stale_update_lock
      ;;
    *)
      echo "Usage: fakenet-billing-stack {start|restart|restart-app|stop|status|update|clear-update-lock}" >&2
      exit 2
      ;;
  esac
}

if command -v systemctl >/dev/null 2>&1; then
  run_systemd
elif command -v rc-service >/dev/null 2>&1; then
  run_openrc
else
  echo "Service manager tidak dikenali." >&2
  exit 1
fi
