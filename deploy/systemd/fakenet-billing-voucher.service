[Unit]
Description=FAKE.NET Billing Voucher Subweb
PartOf=fakenet-billing-stack.target
Wants=network-online.target fakenet-billing.service
After=network-online.target fakenet-billing.service

[Service]
Type=simple
WorkingDirectory=/opt/fakenet-billing
EnvironmentFile=-/etc/fakenet-billing.env
Environment=SUBWEB_KIND=voucher
ExecStart=/usr/bin/node src/subweb-server.js
Restart=always
RestartSec=5
KillSignal=SIGTERM
SyslogIdentifier=fakenet-billing-voucher

[Install]
WantedBy=multi-user.target
