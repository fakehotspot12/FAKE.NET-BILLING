PORT=8891
HOST=0.0.0.0
SUBWEB_HOST=0.0.0.0
ISOLIR_PORT=8892
VOUCHER_PORT=8893
WIFIKU_PORT=8894
# Isi jika nanti dipublish lewat subdomain Cloudflare/DDNS/static IP.
# ISOLIR_PUBLIC_URL=https://isolir.example.net
# VOUCHER_PUBLIC_URL=https://voucher.example.net
# WIFIKU_PUBLIC_URL=https://wifiku.example.net
BILLING_BASE_URL=http://127.0.0.1:8891
NODE_ENV=production
# Batas waktu instal dependency saat install/update (detik).
FAKENET_NPM_INSTALL_TIMEOUT_SECONDS=600
APP_MODE=standalone
BILLING_SOURCE=local
MIGRATION_MODE=0
RADBOOX_AUTO_SYNC=0
STORAGE=postgres
APP_DATABASE_NAME=fakenet_billing
APP_DATABASE_USER=fakenet_billing
APP_DATABASE_PASSWORD=CHANGE_ME_APP_DB_PASSWORD
DATABASE_URL=postgres://fakenet_billing:CHANGE_ME_APP_DB_PASSWORD@127.0.0.1:5432/fakenet_billing

# Mesin pelanggan hasil install wajib aktivasi lisensi.
LICENSE_ENFORCE=1
# Mode rilis: isi public key Ed25519 dari pengelola lisensi.
# LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# Fallback dev saja jika belum memakai public/private key.
# LICENSE_SECRET=change-this-license-secret

REDIS_URL=redis://127.0.0.1:6379/0
REDIS_CACHE_TTL_SECONDS=60
REDIS_TIMEOUT_MS=1000
REDIS_STORE_KEY=fakenet-billing:production:store:main

FREERADIUS_SYNC_ENABLED=1
FREERADIUS_SYNC_DRIVER=postgres
RADIUS_DATABASE_NAME=radius
RADIUS_DATABASE_USER=radius
RADIUS_DATABASE_PASSWORD=CHANGE_ME_RADIUS_DB_PASSWORD
FREERADIUS_DATABASE_URL=postgres://radius:CHANGE_ME_RADIUS_DB_PASSWORD@127.0.0.1:5432/radius
RADIUS_ISOLATION_RATE_LIMIT=128k/128k
RADIUS_ISOLATION_MIKROTIK_GROUP=
RADIUS_ISOLATION_POOL=
RADIUS_SESSION_CACHE_TTL_SECONDS=300
RADIUS_SESSION_STALE_MINUTES=30
RADIUS_CONNECTOR_INTERVAL_MS=15000
RADIUS_CONNECTOR_LIMIT=3000

BILLING_AUTOMATION_INTERVAL_MS=300000
WA_GATEWAY_SEND_INTERVAL_MS=30000
WA_GATEWAY_HTTP_TIMEOUT_MS=15000
