PORT=8891
HOST=0.0.0.0
SUBWEB_HOST=0.0.0.0
ISOLIR_PORT=8892
VOUCHER_PORT=8893
WIFIKU_PORT=8894
NODE_ENV=standalone-dev
APP_MODE=standalone
BILLING_SOURCE=local
RADBOOX_AUTO_SYNC=0
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=billing123
APP_ADMIN_NAME=Admin Billing

# Tahap berikutnya: postgres
STORAGE=json
DATABASE_URL=postgres://user:password@127.0.0.1:5432/fakenet_billing_standalone_dev

# Lisensi. Mesin rilis gunakan LICENSE_ENFORCE=1 dan public key Ed25519.
LICENSE_ENFORCE=0
# LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# LICENSE_SECRET=dev-only-secret

# Command update aman dari menu Pengaturan.
FAKENET_UPDATE_COMMAND=/usr/local/bin/fakenet-billing-update
FAKENET_UPDATE_LOG=/var/log/fakenet-billing/update.log

# Redis cache store. Redis hanya cache, database/file tetap sumber permanen.
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_CACHE_TTL_SECONDS=60
REDIS_TIMEOUT_MS=1000
REDIS_STORE_KEY=fakenet-billing:dev:store:main

# FreeRADIUS SQL writer. Default off agar data bisa disiapkan dulu tanpa menyentuh radius produksi.
FREERADIUS_SYNC_ENABLED=0
FREERADIUS_SYNC_DRIVER=postgres
FREERADIUS_DATABASE_URL=postgres://radius:password@127.0.0.1:5432/radius
RADIUS_ISOLATION_RATE_LIMIT=128k/128k
RADIUS_ISOLATION_MIKROTIK_GROUP=
RADIUS_ISOLATION_POOL=
RADIUS_SESSION_CACHE_TTL_SECONDS=300
RADIUS_CONNECTOR_INTERVAL_MS=15000
RADIUS_CONNECTOR_LIMIT=3000

# Billing automation dan WA sender.
BILLING_AUTOMATION_INTERVAL_MS=300000
WA_GATEWAY_SEND_INTERVAL_MS=30000
WA_GATEWAY_HTTP_TIMEOUT_MS=15000

# WA Gateway sendiri memakai WAHA lokal.
WAHA_PORT=8895
WAHA_API_KEY=isi-api-key-waha-panjang
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=isi-password-dashboard-panjang
